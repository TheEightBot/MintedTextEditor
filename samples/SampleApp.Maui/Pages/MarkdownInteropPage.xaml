<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:minted="https://schemas.mintedtexteditor.com/2026"
             x:Class="SampleApp.Maui.Pages.MarkdownInteropPage"
             Title="Markdown Interop">

    <Grid RowDefinitions="*,Auto,Auto,160">

        <!-- Live editor -->
        <minted:MintedEditorView x:Name="Editor" Grid.Row="0" />

        <!-- Action buttons -->
        <HorizontalStackLayout Grid.Row="1" Spacing="8" Padding="8,6"
                               BackgroundColor="#F0F0F0">
            <Button Text="Export Markdown" Clicked="OnExportClicked"
                    BackgroundColor="#0078D4" TextColor="White"
                    HeightRequest="36" />
            <Button Text="Import Markdown" Clicked="OnImportClicked"
                    BackgroundColor="#107C10" TextColor="White"
                    HeightRequest="36" />
            <Button Text="Append Markdown" Clicked="OnAppendClicked"
                    BackgroundColor="#7A7574" TextColor="White"
                    HeightRequest="36" />
        </HorizontalStackLayout>

        <Label Grid.Row="2" Text="Markdown Source (edit and tap Import):"
               Padding="8,4,8,2" FontSize="12" TextColor="#555" />

        <!-- Markdown source textarea -->
        <Editor x:Name="MarkdownSource"
                Grid.Row="3"
                Placeholder="Paste Markdown here then tap Import…"
                BackgroundColor="#1E1E2E"
                TextColor="#CDD6F4"
                FontFamily="Courier New"
                FontSize="12"
                Margin="8,0,8,8" />
    </Grid>

</ContentPage>
