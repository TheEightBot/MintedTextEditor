<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:minted="https://schemas.mintedtexteditor.com/2026"
             x:Class="SampleApp.Maui.Pages.ReadOnlyPage"
             Title="Read-Only Mode">

    <Grid RowDefinitions="Auto,*">

        <HorizontalStackLayout Grid.Row="0" Padding="12,8" Spacing="12"
                               BackgroundColor="#F0F0F0">
            <Label Text="Read-Only:" VerticalOptions="Center" FontSize="14" />
            <Switch x:Name="ReadOnlySwitch"
                    IsToggled="True"
                    Toggled="OnReadOnlyToggled"
                    VerticalOptions="Center" />
            <Label x:Name="LblMode" Text="On" VerticalOptions="Center"
                   TextColor="#555" FontSize="13" />
        </HorizontalStackLayout>

        <minted:MintedEditorView
            x:Name="Editor"
            Grid.Row="1"
            IsReadOnly="True" />

    </Grid>

</ContentPage>
